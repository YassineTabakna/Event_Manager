<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_input"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:paddingTop="@dimen/screen_padding_top"
    android:paddingBottom="@dimen/screen_padding_bottom">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView android:id="@+id/tvEventName"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="16sp" android:textStyle="bold"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PENDING"
            android:textColor="#FFA000"
            android:textSize="11sp" android:textStyle="bold"
            android:background="#33FFA000"
            android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvEventDate"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/white_60" android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <TextView android:id="@+id/tvAppliedDate"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/gold" android:textSize="12sp"/>

</LinearLayout>