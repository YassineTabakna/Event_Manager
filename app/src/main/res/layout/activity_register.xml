<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_dark"
    android:paddingTop="@dimen/screen_padding_top"
    android:paddingBottom="@dimen/screen_padding_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Back + Title -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/gold"
            android:textSize="14sp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create account"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the event community"
            android:textColor="@color/white_60"
            android:textSize="15sp"
            android:layout_marginBottom="40dp"/>

        <!-- Row: Nom + Prenom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAST NAME" android:textColor="@color/gold"
                    android:textSize="11sp" android:letterSpacing="0.12"
                    android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etNom"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="Dupont" android:textColorHint="@color/white_20"
                    android:textColor="@color/white" android:textSize="15sp"
                    android:paddingHorizontal="12dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FIRST NAME" android:textColor="@color/gold"
                    android:textSize="11sp" android:letterSpacing="0.12"
                    android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etPrenom"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="Jean" android:textColorHint="@color/white_20"
                    android:textColor="@color/white" android:textSize="15sp"
                    android:paddingHorizontal="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Email -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="EMAIL" android:textColor="@color/gold" android:textSize="11sp"
            android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:background="@drawable/bg_input" android:hint="your@email.com"
            android:textColorHint="@color/white_20" android:textColor="@color/white"
            android:inputType="textEmailAddress" android:paddingHorizontal="16dp"
            android:layout_marginBottom="20dp"/>

        <!-- Username -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="USERNAME" android:textColor="@color/gold" android:textSize="11sp"
            android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etUsername"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:background="@drawable/bg_input" android:hint="@username"
            android:textColorHint="@color/white_20" android:textColor="@color/white"
            android:paddingHorizontal="16dp" android:layout_marginBottom="20dp"/>

        <!-- Password -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PASSWORD" android:textColor="@color/gold" android:textSize="11sp"
            android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etPassword"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:background="@drawable/bg_input" android:hint="••••••••"
            android:textColorHint="@color/white_20" android:textColor="@color/white"
            android:inputType="textPassword" android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"/>

        <!-- Password strength -->
        <TextView android:id="@+id/tvPasswordStrength"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="12sp" android:lineSpacingExtra="3dp"
            android:layout_marginBottom="20dp"/>

        <!-- Date -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DATE OF BIRTH" android:textColor="@color/gold" android:textSize="11sp"
            android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etDate"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:background="@drawable/bg_input" android:hint="YYYY-MM-DD"
            android:textColorHint="@color/white_20" android:textColor="@color/white"
            android:paddingHorizontal="16dp" android:layout_marginBottom="32dp"/>

        <!-- Register Button -->
        <Button android:id="@+id/btnRegister"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:background="@drawable/bg_button_gold"
            android:text="CREATE ACCOUNT"
            android:textColor="@color/navy_dark" android:textSize="14sp"
            android:textStyle="bold" android:letterSpacing="0.08"/>

    </LinearLayout>
</ScrollView>